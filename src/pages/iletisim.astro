---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="İletişim | Denizli Zeynep Ticaret"
  description="Zeynep Ticaret ile iletişime geçin. Denizli Pamukkale'deki mağazamızı ziyaret edin veya WhatsApp, telefon ve sosyal medya üzerinden ulaşın. Adres: Hacıkaplanlar, Barış Cd. No:34, Pamukkale/Denizli."
  canonical="https://zeynepticaret.com/iletisim"
>
  <Navigation />

  <main class="pt-24 pb-16 bg-stone-50">
    <div class="max-w-4xl mx-auto px-6">

      <!-- Header -->
      <header class="mb-12">
        <p class="text-xs uppercase tracking-widest text-stone-400 mb-4">Zeynep Ticaret</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-stone-900 mb-4">İletişim</h1>
        <p class="text-lg text-stone-500">
          Denizli'deki mağazamıza bekleriz. Soru ve siparişleriniz için aşağıdaki kanallardan bize ulaşabilirsiniz.
        </p>
      </header>

      <div class="grid md:grid-cols-2 gap-8">

        <!-- Contact Info -->
        <div class="space-y-6">

          <!-- Address -->
          <div class="bg-white rounded-2xl p-8 border border-stone-200">
            <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">Mağaza Adresimiz</p>
            <address class="not-italic">
              <p class="text-stone-900 font-medium text-lg leading-relaxed">
                Hacıkaplanlar, Barış Cd. No:34<br />
                20100 Pamukkale / Denizli
              </p>
            </address>
            <a
              href="https://www.google.com/maps?sca_esv=5aba584b8a922c2c&sxsrf=ANbL-n4puEjQejf4UMxcEYAVyYEUN5GryA:1774391336478&kgmid=/g/11ppzcv1gq&shem=dlvsc&shndl=30&kgs=e1a1ceed519b971f&um=1&ie=UTF-8&fb=1&gl=tr&sa=X&geocode=KSlCunZdP8cUMbI_rt0kbqSp&daddr=Hac%C4%B1kaplanlar,+Bar%C4%B1%C5%9F+Cd.+No:34,+20100+Pamukkale/Denizli"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-4 text-sm text-stone-500 underline hover:text-stone-900 transition-colors"
            >
              Google Maps'te Aç →
            </a>
          </div>

          <!-- Phone & Hours -->
          <div class="bg-white rounded-2xl p-8 border border-stone-200">
            <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">Telefon</p>
            <a
              href="tel:+905383045524"
              class="text-stone-900 font-medium text-lg hover:text-stone-600 transition-colors"
            >
              0538 304 55 24
            </a>
            <div class="mt-6 pt-6 border-t border-stone-100">
              <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">Çalışma Saatleri</p>
              <p class="text-stone-900 font-medium">Pazartesi – Cumartesi</p>
              <p class="text-stone-500 text-sm">09:00 – 19:00</p>
            </div>
          </div>

          <!-- Social -->
          <div class="bg-white rounded-2xl p-8 border border-stone-200">
            <p class="text-xs uppercase tracking-widest text-stone-400 mb-4">Sosyal Medya</p>
            <div class="flex flex-col gap-3">
              <a
                href="https://www.instagram.com/zeynepticarett/"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors group"
              >
                <svg class="w-5 h-5 fill-current shrink-0" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266.057 1.645.069 4.849.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
                <span class="font-medium">@zeynepticarett</span>
              </a>
              <a
                href="https://www.facebook.com/zeynepticaretz"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors"
              >
                <svg class="w-5 h-5 fill-current shrink-0" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                <span class="font-medium">Zeynep Ticaret</span>
              </a>
              <a
                href="https://store.zeynepticaretdenizli.com"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-stone-700 hover:text-stone-900 transition-colors"
              >
                <svg class="w-5 h-5 fill-none stroke-current shrink-0" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
                <span class="font-medium">store.zeynepticaretdenizli.com</span>
              </a>
            </div>
          </div>

        </div>

        <!-- WhatsApp CTA + Map -->
        <div class="space-y-6">

          <!-- WhatsApp -->
          <a
            href="https://wa.me/905383045524"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-4 w-full bg-[#25D366] text-white font-bold py-6 rounded-2xl hover:shadow-lg hover:scale-[1.02] transition-all text-lg"
          >
            <svg class="w-7 h-7 fill-current shrink-0" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp'tan Yazın
          </a>

          <!-- Map -->
          <div class="rounded-2xl overflow-hidden border border-stone-200 h-72">
            <iframe
              title="Zeynep Ticaret Denizli Harita"
              src="https://maps.google.com/maps?q=Hac%C4%B1kaplanlar%2C%20Bar%C4%B1%C5%9F%20Cd.%20No%3A34%2C%2020100%20Pamukkale%2FDenizli&t=&z=16&ie=UTF8&iwloc=&output=embed"
              class="w-full h-full border-0"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

          <!-- Online Store -->
          <div class="bg-stone-900 rounded-2xl p-8 text-center">
            <p class="text-stone-400 text-sm uppercase tracking-widest mb-3">Denizli'ye gelemiyorsanız</p>
            <h2 class="font-serif text-2xl font-bold text-white mb-4">Online Mağazamız Açık</h2>
            <p class="text-stone-400 text-sm mb-6">Tüm Türkiye'ye hızlı kargo. Güvenli ödeme.</p>
            <a
              href="https://store.zeynepticaretdenizli.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center bg-white text-stone-900 text-sm font-bold px-6 py-3 rounded-full hover:bg-stone-100 transition-all"
            >
              Alışverişe Başla
            </a>
          </div>

        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
