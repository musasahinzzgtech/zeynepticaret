---
import Layout from '@/layouts/Layout.astro';
import Navigation from '@/components/Navigation.astro';
import Hero from '@/components/Hero.astro';
import Collections from '@/components/Collections.astro';
import AboutContact from '@/components/AboutContact.astro';
import StoreMap from '@/components/StoreMap.astro';
import Footer from '@/components/Footer.astro';

const title = 'Zeynep Ticaret | Ev Dekoru ve Yaşam Alanları';
const description =
  "Zeynep Ticaret - Denizli'den tüm Türkiye'ye uzanan özel dekoratif objeler ve ev aksesuarları koleksiyonu.";
const canonical = 'https://zeynepticaret.com';
---

<Layout title={title} description={description} canonical={canonical}>
  <Navigation />
  <main>
    <Hero />
    <Collections />
    <AboutContact />
    <StoreMap />
  </main>
  <Footer />
</Layout>
