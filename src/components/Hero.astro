---
// Hero section with SEO-friendly content and accessible images
---

<section
  class="relative min-h-screen pt-20 flex flex-col lg:flex-row overflow-hidden"
  data-purpose="hero"
>
  <!-- Left Content -->
  <div class="w-full lg:w-1/2 flex items-center px-6 lg:px-16 py-12 lg:py-0 z-10 bg-stone-50">
    <div class="max-w-xl animate-fade-in-up">
      <span class="inline-block text-stone-500 font-medium tracking-[0.3em] uppercase mb-6 text-sm">
        Denizli'den İlhamla
      </span>
      <h1 class="font-serif text-5xl md:text-7xl leading-[1.1] mb-8 text-balance">
        Evinize Kendi <span class="italic">İmzanızı</span> Atın.
      </h1>
      <p class="text-stone-500 text-lg md:text-xl leading-relaxed mb-10">
        Zeynep Ticaret olarak, yaşam alanlarınıza ruh katan en özel detayları bir araya getiriyoruz.
        Denizli'den tüm Türkiye'ye uzanan kürasyonumuzla tanışın.
      </p>
      <a
        class="group inline-flex items-center gap-4 text-stone-900 font-semibold text-lg tracking-wide border-b-2 border-stone-900 pb-1 hover:gap-6 transition-all"
        href="https://ikas.com"
        target="_blank"
        rel="noopener noreferrer"
        title="İkas Mağazamız"
      >
        İkas Mağazamızda Keşfedin
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewbox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-linecap="round" stroke-linejoin="round"
            stroke-width="2"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Right Image -->
  <div class="w-full lg:w-1/2 relative h-[50vh] lg:h-auto overflow-hidden">
    <img
      alt="Rahat oturma odası, dekoratif vazo ve ev aksesuarları"
      class="absolute inset-0 w-full h-full object-cover asymmetric-clip animate-reveal"
      src="/hero.jpg"
      width="800"
      height="600"
      loading="eager"
    />
    <div class="absolute bottom-10 left-10 lg:left-48 text-white z-20 hidden md:block">
      <p class="font-serif italic text-2xl font-light">"Zarafet, ayrıntılarda gizlidir."</p>
    </div>
  </div>
</section>
