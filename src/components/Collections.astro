---

<section
  class="py-24 px-6 lg:px-16 bg-white"
  data-purpose="collections"
  id="koleksiyonlar"
>
  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div class="max-w-2xl">
        <h2 class="font-serif text-4xl md:text-5xl mb-6">Özenle Seçilmiş Koleksiyonlar</h2>
        <p class="text-stone-500 text-lg">
          Sezonun trendlerini, zamansız klasikler ve el işçiliği ile harmanladık. Her parça eviniz
          için yeni bir hikaye.
        </p>
      </div>
      <button
        class="px-8 py-3 border border-stone-900 rounded-full text-sm font-bold uppercase tracking-widest hover:bg-stone-900 hover:text-white transition-all duration-300"
        title="Tüm ürünleri incele"
      >
        Tüm Ürünleri İncele
      </button>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 grid-rows-2 gap-6 h-auto lg:h-[800px]">
      {
        collections.map((item) => (
          <div
            class={`${item.span || ''} relative group overflow-hidden bg-stone-100 rounded-sm`}
          >
            <img
              alt={item.altText}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              src={item.imageSrc}
              width="600"
              height="600"
              loading="lazy"
            />
            {item.span === 'md:col-span-2 md:row-span-2' && (
              <div class="absolute inset-0 bg-gradient-to-t from-stone-900/60 via-transparent to-transparent opacity-60"></div>
            )}
            {item.span !== 'md:col-span-2 md:row-span-2' && item.span !== 'md:col-span-2 md:row-span-1' && (
              <div class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors"></div>
            )}
            {item.span === 'md:col-span-2 md:row-span-1' && (
              <div class="absolute inset-0 bg-gradient-to-r from-stone-900/40 to-transparent"></div>
            )}

            <div
              class={`absolute ${item.span === 'md:col-span-2 md:row-span-2' ? 'bottom-0 left-0 p-8' : item.span === 'md:col-span-2 md:row-span-1' ? 'inset-0 flex flex-col justify-center p-8' : 'inset-0 flex flex-col justify-end p-6'}`}
            >
              <h3
                class={`font-serif ${item.span === 'md:col-span-2 md:row-span-2' ? 'text-3xl' : item.span === 'md:col-span-2 md:row-span-1' ? 'text-2xl mb-2' : 'text-xl'} text-white mb-${item.span === 'md:col-span-2 md:row-span-1' ? '2' : '0'}`}
              >
                {item.title}
              </h3>
              {item.description && (
                <p class="text-stone-200 text-sm max-w-xs">{item.description}</p>
              )}
              {!item.description && (
                <span class="text-stone-200 text-sm tracking-widest uppercase">Koleksiyonu Keşfet</span>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
